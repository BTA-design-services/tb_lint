{
  "project": {
    "name": "<PROJECT_NAME>",
    "company": "<COMPANY_NAME>",
    "description": "<PROJECT_DESCRIPTION>"
  },
  "file_header": {
    "required_fields": [
      "File"
    ],
    "recommended_fields": [
      "Company",
      "Author"
    ],
    "company_name": "<COMPANY_NAME>",
    "company_pattern": "<COMPANY_PATTERN>",
    "email_domain": "<EMAIL_DOMAIN>",
    "file_header_template": [
      "// File: <filename>",
      "// Company: <company>",
      "// Author: <name> <email>",
      "// Date: <date>",
      "// Description: <description>"
    ]
  },
  "linter_rules": {
    "[ND_FILE_HDR]": true,
    "[ND_INCLUDE_GRD]": true,
    "[ND_PKG]": true,
    "[ND_CLASS]": true,
    "[ND_FUNC]": true,
    "[ND_TASK]": true,
    "[ND_CONST]": true,
    "[ND_TYPEDEF]": true,
    "[ND_VAR]": true,
    "[ND_PARAM]": true,
    "[ND_END_NAMED]": true
  },
  "severity_levels": {
    "[ND_FILE_HDR_MISS]": "ERROR",
    "[ND_COMPANY_MISS]": "WARNING",
    "[ND_AUTHOR_MISS]": "WARNING",
    "[ND_GUARD_MISS]": "ERROR",
    "[ND_GUARD_FMT]": "ERROR",
    "[ND_PKG_MISS]": "ERROR",
    "[ND_CLASS_MISS]": "ERROR",
    "[ND_FUNC_MISS]": "ERROR",
    "[ND_TASK_MISS]": "ERROR",
    "[ND_CONST_MISS]": "ERROR",
    "[ND_TYPEDEF_MISS]": "ERROR",
    "[ND_VAR_MISS]": "ERROR",
    "[ND_PARAM_MISS]": "ERROR",
    "[ND_END_NAMED_MISS]": "ERROR",
    "[ND_NAME_MISMATCH]": "ERROR",
    "[ND_WRONG_KW]": "ERROR",
    "[ND_INVALID_KW]": "ERROR"
  },
  "naming_conventions": {
    "prefix_package": "<PREFIX_PACKAGE>",
    "suffix_package": "_pkg",
    "prefix_class": "<PREFIX_CLASS>",
    "prefix_interface": "",
    "suffix_interface": "_if",
    "prefix_member_variable": "m_",
    "suffix_constraint": "_c",
    "suffix_type": "_t"
  },
  "output": {
    "use_color": false,
    "verbose": false,
    "show_context": true
  },
  "metadata": {
    "config_version": "<CONFIG_VERSION>",
    "last_updated": "<DATE>",
    "maintainer": "<TEAM_OR_OWNER>"
  }
}
